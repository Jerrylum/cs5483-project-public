{
  "name": "Statistics API",
  "image": "oven/bun:latest",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "forwardPorts": [8081],
  "postCreateCommand": "bun install",
  "customizations": {
    "vscode": {
      "extensions": ["ms-typescript.typescript-language-features", "dbaeumer.vscode-eslint"]
    }
  },
  "runArgs": ["--add-host", "host.docker.internal:host-gateway", "--publish", "8081:8081"]
}
